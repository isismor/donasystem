# === Torre Dona ===
PORT=3000

# === Authentication ===
AUTH_USER=admin
AUTH_PASS=change-me
API_KEY=generate-a-random-key
AUTH_SECRET=generate-a-random-secret

# === Access Control ===
MC_COOKIE_SECURE=
MC_COOKIE_SAMESITE=strict
MC_ALLOW_ANY_HOST=true
MC_ALLOWED_HOSTS=localhost,127.0.0.1

# === OpenClaw Integration ===
OPENCLAW_HOME=/home/openclaw/.openclaw
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_TOOLS_PROFILE=coding

# === Gateway Frontend ===
MC_DEFAULT_GATEWAY_NAME=Dona
NEXT_PUBLIC_GATEWAY_HOST=127.0.0.1
NEXT_PUBLIC_GATEWAY_PORT=18789
NEXT_PUBLIC_GATEWAY_PROTOCOL=
NEXT_PUBLIC_GATEWAY_URL=
NEXT_PUBLIC_GATEWAY_CLIENT_ID=torre-dona
